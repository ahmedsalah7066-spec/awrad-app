<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/backgroundBeige">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/primaryGreen" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="16dp" android:paddingTop="48dp" android:paddingBottom="16dp">

        <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_arrow_back" app:tint="@color/white" android:contentDescription="@string/back" />

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/about_app" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:fontFamily="serif" android:gravity="center" android:layout_marginEnd="24dp" />
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

            <!-- App Icon + Name -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:paddingVertical="24dp">

                <ImageView android:layout_width="80dp" android:layout_height="80dp" android:src="@mipmap/ic_launcher_round" android:contentDescription="@string/app_name" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_name_title" android:textColor="@color/primaryGreen" android:textSize="22sp" android:textStyle="bold" android:fontFamily="serif" android:layout_marginTop="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_version" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Description Card -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/about_app_desc_1" android:textColor="@color/textDark" android:textSize="14sp" android:lineSpacingMultiplier="1.5" android:gravity="end|right" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="12dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/about_app_desc_2" android:textColor="@color/textDark" android:textSize="14sp" android:lineSpacingMultiplier="1.5" android:gravity="end|right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Features Title -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/app_features" android:textColor="@color/primaryGreen" android:textSize="17sp" android:textStyle="bold" android:fontFamily="serif" android:layout_marginBottom="10dp" android:gravity="end|right" />

            <!-- Feature: Awrad -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_info" app:tint="@color/primaryGreen"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_awrad" android:textColor="@color/textDark" android:textSize="15sp" android:textStyle="bold" android:gravity="end|right"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_awrad_desc" android:textColor="#777777" android:textSize="12sp" android:gravity="end|right" android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature: Munajat -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_prayer" app:tint="@color/primaryGreen"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_munajat" android:textColor="@color/textDark" android:textSize="15sp" android:textStyle="bold" android:gravity="end|right"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_munajat_desc" android:textColor="#777777" android:textSize="12sp" android:gravity="end|right" android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature: Hisn -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_morning" app:tint="@color/primaryGreen"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_hisn" android:textColor="@color/textDark" android:textSize="15sp" android:textStyle="bold" android:gravity="end|right"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_hisn_desc" android:textColor="#777777" android:textSize="12sp" android:gravity="end|right" android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature: Notifications -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_notification" app:tint="@color/primaryGreen"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_notifications" android:textColor="@color/textDark" android:textSize="15sp" android:textStyle="bold" android:gravity="end|right"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_notifications_desc" android:textColor="#777777" android:textSize="12sp" android:gravity="end|right" android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature: Multilingual -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_language" app:tint="@color/primaryGreen"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_multilingual" android:textColor="@color/textDark" android:textSize="15sp" android:textStyle="bold" android:gravity="end|right"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_multilingual_desc" android:textColor="#777777" android:textSize="12sp" android:gravity="end|right" android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature: Sharing -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_share" app:tint="@color/primaryGreen"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_sharing" android:textColor="@color/textDark" android:textSize="15sp" android:textStyle="bold" android:gravity="end|right"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_sharing_desc" android:textColor="#777777" android:textSize="12sp" android:gravity="end|right" android:lineSpacingMultiplier="1.4"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Footer Dua -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" app:cardBackgroundColor="#FFF8E7" app:cardCornerRadius="12dp" app:cardElevation="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/footer_dua" android:textColor="@color/textDark" android:textSize="13sp" android:fontFamily="serif" android:gravity="center" android:lineSpacingMultiplier="1.6"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/footer_ameen" android:textColor="@color/primaryGreen" android:textSize="14sp" android:textStyle="bold" android:fontFamily="serif" android:gravity="center" android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
