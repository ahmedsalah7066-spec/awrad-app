<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/backgroundBeige" tools:context=".AboutActivity">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/primaryGreen" android:gravity="center_vertical" android:padding="16dp" android:orientation="horizontal">


        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/about_app" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:fontFamily="serif" android:gravity="center" android:layout_marginEnd="24dp"/>

    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

            <!-- App Info Card -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@android:color/transparent" android:background="@drawable/card_background" app:cardCornerRadius="12dp" app:cardElevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp" android:gravity="center">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_name_title" android:textColor="@color/primaryGreen" android:textSize="24sp" android:textStyle="bold" android:fontFamily="serif" android:layout_marginBottom="8dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/app_version" android:textColor="#777777" android:textSize="14sp" android:layout_marginBottom="24dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/about_app_desc_1" android:textColor="@color/textDark" android:textSize="16sp" android:gravity="center" android:lineSpacingExtra="6dp" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/about_app_desc_2" android:textColor="@color/textDark" android:textSize="16sp" android:gravity="center" android:lineSpacingExtra="6dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Features Section -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/app_features" android:textColor="@color/textDark" android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="12dp" android:layout_marginEnd="8dp"/>

            <!-- Feature 1 -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@android:color/transparent" android:background="@drawable/card_background" app:cardCornerRadius="12dp" app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp">

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_prayer" app:tint="@color/primaryGreen" android:layout_marginTop="4dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_awrad" android:textColor="@color/textDark" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="4dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_awrad_desc" android:textColor="#555555" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature 2 -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@android:color/transparent" android:background="@drawable/card_background" app:cardCornerRadius="12dp" app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp">

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_mosque" app:tint="@color/primaryGreen" android:layout_marginTop="4dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_munajat" android:textColor="@color/textDark" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="4dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_munajat_desc" android:textColor="#555555" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature 3 -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@android:color/transparent" android:background="@drawable/card_background" app:cardCornerRadius="12dp" app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp">

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_tasbeehat" app:tint="@color/primaryGreen" android:layout_marginTop="4dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_tasbih" android:textColor="@color/textDark" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="4dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_tasbih_desc" android:textColor="#555555" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature: Multilingual Support -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@android:color/transparent" android:background="@drawable/card_background" app:cardCornerRadius="12dp" app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp">

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_language" app:tint="@color/primaryGreen" android:layout_marginTop="4dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_multilingual" android:textColor="@color/textDark" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="4dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_multilingual_desc" android:textColor="#555555" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature: Hisn Al-Muslim -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@android:color/transparent" android:background="@drawable/card_background" app:cardCornerRadius="12dp" app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp">

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_prayer" app:tint="@color/primaryGreen" android:layout_marginTop="4dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_hisn" android:textColor="@color/textDark" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="4dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_hisn_desc" android:textColor="#555555" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feature 4: Notifications -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" app:cardBackgroundColor="@android:color/transparent" android:background="@drawable/card_background" app:cardCornerRadius="12dp" app:cardElevation="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp">

                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_notification" app:tint="@color/primaryGreen" android:layout_marginTop="4dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_notifications" android:textColor="@color/textDark" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="4dp"/>

                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/feature_notifications_desc" android:textColor="#555555" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



            <!-- Footer Dua -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" app:cardBackgroundColor="#E8E6D9" app:cardCornerRadius="16dp" app:cardElevation="0dp" app:strokeColor="@color/primaryGreen" app:strokeWidth="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp" android:gravity="center">

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/footer_dua" android:textColor="@color/textDark" android:textSize="16sp" android:gravity="center" android:fontFamily="serif" android:lineSpacingExtra="6dp" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/footer_ameen" android:textColor="@color/primaryGreen" android:textSize="18sp" android:textStyle="bold" android:gravity="center" android:fontFamily="serif"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
