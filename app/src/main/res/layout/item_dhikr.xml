<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@color/cardBackground" app:cardCornerRadius="12dp" app:cardElevation="2dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

        <!-- Arabic Text -->
        <TextView android:id="@+id/tvArabic" android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="serif" android:lineSpacingMultiplier="1.5" android:text="Arabic Text Here" android:textAlignment="center" android:textColor="@color/primaryGreen" android:textSize="22sp" android:textStyle="bold" />

        <!-- Translation/Explanation -->
        <TextView android:id="@+id/tvTranslation" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:lineSpacingMultiplier="1.2" android:text="Translation Here" android:textAlignment="center" android:textColor="#555555" android:textSize="16sp" />

        <!-- Counter Section -->
        <LinearLayout android:id="@+id/layoutCounter" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:gravity="center" android:orientation="horizontal">

            <com.google.android.material.progressindicator.CircularProgressIndicator android:id="@+id/progressIndicator" android:layout_width="wrap_content" android:layout_height="wrap_content" android:max="100" android:progress="0" app:indicatorColor="@color/primaryGreen" app:trackColor="#E0E0E0" app:trackThickness="4dp" />

            <TextView android:id="@+id/tvCounter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="0 / 3" android:textColor="@color/primaryGreen" android:textSize="18sp" android:textStyle="bold" />

        </LinearLayout>

        <TextView android:id="@+id/tvTapHint" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center" android:text="Tap to count" android:textSize="12sp" android:textColor="#999999"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
