    <!-- About App Strings -->
    <string name="app_name_title">Evrad Uygulaması</string>
    <string name="app_version">Sürüm 2.3.2</string>
    <string name="about_app_desc_1">Evrad, Günlük Zikirleri ve İmam Zeynel Abidin\'in (ra) Münacaatlarını birleştiren kapsamlı bir İslami uygulamadır. Günlük hayatınızda zikir ve duaya devam etmenize yardımcı olmak için tasarlanmıştır.</string>
    <string name="about_app_desc_2">Uygulama, ibadet ve maneviyata odaklanmanıza yardımcı olan, gözü yormayan şık bir tasarıma ve basit, kullanıcı dostu bir arayüze sahiptir.</string>
    <string name="app_features">Uygulama Özellikleri</string>
    <string name="feature_awrad">Günlük Evrad</string>
    <string name="feature_awrad_desc">Haftanın her günü için yedi farklı vird; Peygamber Efendimiz (s.a.v) üzerine salavatlar ve doğru telaffuz için tamamen harekeli mübarek dualar içerir.</string>
    <string name="feature_munajat">İmam Zeynel Abidin Münacaatları</string>
    <string name="feature_munajat_desc">Sahife-i Seccadiye\'den on beş mübarek münacaat, günlük virdlerle bağlantılı olup, herhangi bir zamanda okunabilir.</string>
    <string name="feature_hisn">Hısnü\'l Müslim</string>
    <string name="feature_hisn_desc">Sabah ve Akşam, Uyku, Namaz, Yemek, Yolculuk ve Cami zikirleri dahil olmak üzere kapsamlı zikir kütüphanesi.</string>
    <string name="feature_notifications">Akıllı Bildirimler</string>
    <string name="feature_notifications_desc">Belirli zamanlarda sizi zikre ve Salavat\'a teşvik eden, sıklığı ve tonu özelleştirilebilir esnek bildirim sistemi.</string>
    <string name="feature_settings">Tam Özelleştirme</string>
    <string name="feature_settings_desc">Yazı boyutu, gece modu (otomatik/manuel) ve uygulama dili üzerinde tam kontrol.</string>
