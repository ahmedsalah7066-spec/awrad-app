    <!-- About App Strings -->
    <string name="app_name_title">برنامه اوراد</string>
    <string name="app_version">نسخه 2.3.2</string>
    <string name="about_app_desc_1">اوراد (Awrad) یک برنامه کاربردی جامع اسلامی است که اذکار روزانه و مناجات امام زین‌العابدین (ع) را در خود جای داده است. این برنامه به شما در حفظ معنویت در طول روز کمک می‌کند.</string>
    <string name="about_app_desc_2">این برنامه با طراحی ساده و آرامش‌بخش، باعث راحتی چشم شده و به شما کمک می‌کند تماماً روی عبادت تمرکز کنید.</string>
    <string name="app_features">ویژگی‌ها</string>
    <string name="feature_awrad">اوراد روزانه</string>
    <string name="feature_awrad_desc">هفت ورد متفاوت، با درودها و دعاهای مبارک بر پیامبر (ص) به تفکیک روزهای هفته، با تلفظ دقیق.</string>
    <string name="feature_munajat">مناجات امام زین‌العابدین</string>
    <string name="feature_munajat_desc">پانزده مناجات پرفیض از صحیفه سجادیه که هر روز یک مورد به ورد روزانه ضمیمه می‌شود تا در صورت تمایل، هر زمان آن را قرائت کنید.</string>
    <string name="feature_tasbih">تسبیح الکترونیکی</string>
    <string name="feature_tasbih_desc">تسبیح دیجیتال با شمارنده هوشمند و بازخورد لرزشی در هر شمارش.</string>
    <string name="feature_multilingual">پشتیبانی چندزبانه</string>
    <string name="feature_multilingual_desc">پشتیبانی کامل از زبان‌های عربی، انگلیسی، اردو، هندی، مالایالم، فرانسوی، و بنگالی.</string>
    <string name="feature_hisn">حصن المسلم</string>
    <string name="feature_hisn_desc">کتابخانه‌ای کامل از اذکار صبح و عصر، خواب، نماز، غذا، سفر و مسجد.</string>
    <string name="feature_notifications">اعلان‌های یادآوری</string>
    <string name="feature_notifications_desc">یک سیستم یادآوری پیشرفته برای تنظیم زمان یادآوری از هر ۵ دقیقه تا هر ۳ ساعت، برای درود و استغفار.</string>
    <string name="footer_dua">از خداوند متعال مسألت داریم که این کار را صرفاً برای کسب رضای خود بپذیرد، به مسلمانان سود برساند و آن را در کارنامه اعمال نیک تمامی کسانی که در آن سهیم بوده‌اند قرار دهد.</string>
    <string name="footer_ameen">آمین، یا رب العالمین</string>

