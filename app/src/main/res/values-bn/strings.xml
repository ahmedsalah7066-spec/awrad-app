    <!-- About App Strings -->
    <string name="app_name_title">আওরাদ অ্যাপ্লিকেশন</string>
    <string name="app_version">সংস্করণ 2.3.2</string>
    <string name="about_app_desc_1">আওরাদ (Awrad) একটি পূর্ণাঙ্গ ইসলামিক অ্যাপ যা দৈনিক যিকির এবং ইমাম জয়নুল আবিদীন (আঃ) এর মোনাজাত সংগ্রহ করে। এটি আপনার দৈনন্দিন জীবনে আধ্যাত্মিকতা বজায় রাখতে সহায়তা করে।</string>
    <string name="about_app_desc_2">অ্যাপটি একটি সহজ এবং শান্ত নকশা অফার করে যা চোখের জন্য আরামদায়ক, এবং আপনাকে পুরোপুরি ইবাদতে মনোযোগ দিতে সহায়তা করে।</string>
    <string name="app_features">বৈশিষ্ট্যসমূহ</string>
    <string name="feature_awrad">দৈনিক আওরাদ</string>
    <string name="feature_awrad_desc">সপ্তাহের প্রতি দিনের জন্য নির্দিষ্ট সাতটি ভিন্ন উইরদ, যাতে রয়েছে সঠিক উচ্চারণ সহকারে নবী (সাঃ) এর প্রতি দরূদ এবং বরকতময় দোয়া।</string>
    <string name="feature_munajat">ইমাম জয়নুল আবিদীনের মোনাজাত</string>
    <string name="feature_munajat_desc">সহিফা সাজ্জাদিয়া থেকে পনেরোটি বরকতময় মোনাজাত যা দৈনিক উইরদের সাথে যুক্ত, চাইলে যেকোনো সময় পড়ার সুবিধা রয়েছে।</string>
    <string name="feature_tasbih">ইলেকট্রনিক তাসবীহ</string>
    <string name="feature_tasbih_desc">স্মার্ট কাউন্টার এবং প্রতি গণনায় ভাইব্রেশন ফিডব্যাকসহ ডিজিটাল তাসবীহ।</string>
    <string name="feature_multilingual">বহুভাষিক সমর্থন</string>
    <string name="feature_multilingual_desc">আরবি, ইংরেজি, উর্দু, হিন্দি, মালায়ালম, ফরাসি, বাংলা এবং আরও অনেক ভাষার জন্য সম্পূর্ণ সমর্থন রয়েছে।</string>
    <string name="feature_hisn">হিসনুল মুসলিম</string>
    <string name="feature_hisn_desc">সকাল ও সন্ধ্যার, ঘুম, নামাজ, খাবার, ভ্রমণ এবং মসজিদের যিকিরের সম্পূর্ণ লাইব্রেরি।</string>
    <string name="feature_notifications">রিমাইন্ডার নোটিফিকেশন</string>
    <string name="feature_notifications_desc">একটি উন্নত நோটিفیکیشن সিস্টেম যা আপনাকে ইস্তেগফার এবং দরূদের জন্য ৫ মিনিট থেকে ৩ ঘণ্টা পর্যন্ত সময় নির্ধারণ করতে দেয়।</string>
    <string name="footer_dua">আমরা মহান আল্লাহর কাছে প্রার্থনা করি তিনি যেন এই কাজটিকে কেবল তাঁর সন্তুষ্টির জন্য কবুল করেন, মুসলমানদের উপকৃত করেন এবং যারা এটিতে অবদান রেখেছেন তাদের নেক আমলের পাল্লায় যুক্ত করেন।</string>
