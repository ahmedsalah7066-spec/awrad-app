    <!-- About App Strings -->
    <string name="app_name_title">Aplikasi Awrad</string>
    <string name="app_version">Versi 2.3.2</string>
    <string name="about_app_desc_1">Awrad adalah aplikasi Islami komprehensif yang menggabungkan Dzikir Harian dan Munajat Imam Zainal Abidin (AS). Dirancang untuk membantu Anda menjaga konsistensi dalam berdzikir dan berdoa dalam kehidupan sehari-hari.</string>
    <string name="about_app_desc_2">Aplikasi ini menampilkan antarmuka yang sederhana dan ramah pengguna dengan desain elegan yang nyaman dipandang, membantu Anda fokus pada ibadah dan spiritualitas.</string>
    <string name="app_features">Fitur Aplikasi</string>
    <string name="feature_awrad">Awrad Harian</string>
    <string name="feature_awrad_desc">Tujuh hizb berbeda untuk setiap hari dalam seminggu, berisi shalawat kepada Nabi ﷺ dan doa-doa pilihan yang berharakat penuh untuk pelafalan yang benar.</string>
    <string name="feature_munajat">Munajat Imam Zainal Abidin</string>
    <string name="feature_munajat_desc">Lima belas Munajat pilihan dari As-Sahifah As-Sajjadiyah, terhubung dengan hizb harian, dengan kemampuan membaca Munajat apa saja kapan saja.</string>
    <string name="feature_tasbih">Tasbih Elektronik</string>
    <string name="feature_tasbih_desc">Tasbih digital berisi tujuh dzikir pilihan dengan penghitung cerdas dan respon getaran pada setiap hitungan.</string>
    <string name="feature_multilingual">Dukungan Multi-bahasa</string>
    <string name="feature_multilingual_desc">Dukungan penuh ditambahkan untuk: Arab, Inggris, Urdu, Hindi, Malayalam, dan Indonesia, menyediakan penjelasan dan terjemahan untuk Awrad dan Munajat.</string>
    <string name="feature_hisn">Hisnul Muslim</string>
    <string name="feature_hisn_desc">Perpustakaan lengkap Dzikir termasuk: Dzikir Pagi &amp; Petang, Tidur, Sholat, Makanan, Perjalanan, dan Dzikir Masjid.</string>
    <string name="feature_notifications">Notifikasi Pengingat</string>
    <string name="feature_notifications_desc">Sistem notifikasi canggih yang memungkinkan Anda mengatur interval pengingat (dari 5 menit hingga 3 jam) untuk Istighfar dan Shalawat.</string>
    <string name="footer_dua">Kami memohon kepada Allah Yang Maha Kuasa untuk menerima karya ini murni demi mengharap ridha-Nya yang mulia, agar bermanfaat bagi kaum Muslimin, dan menjadikannya dalam timbangan amal baik setiap orang yang berkontribusi di dalamnya.</string>
    <string name="footer_ameen">Aamiin, Ya Rabbal \'Alamin</string>

