    <!-- About App Strings -->
    <string name="app_name_title">Приложение Аврод</string>
    <string name="app_version">Версия 2.3.2</string>
    <string name="about_app_desc_1">Аврод (Awrad) — это комплексное исламское приложение, объединяющее ежедневные Азкары и Мунаджаты Имама Зайн аль-Абидина (АС). Создано, чтобы помочь вам поддерживать постоянное поминание и молитву в вашей повседневной жизни.</string>
    <string name="about_app_desc_2">Приложение отличается простым, удобным интерфейсом с элегантным дизайном, приятным для глаз, что помогает вам сосредоточиться на поклонении и духовности.</string>
    <string name="app_features">Функции приложения</string>
    <string name="feature_awrad">Ежедневный Аврод</string>
    <string name="feature_awrad_desc">Семь различных вирдов на каждый день недели, содержащих благословения Пророку ﷺ и благословенные молитвы, полностью огласованные для правильного произношения.</string>
    <string name="feature_munajat">Мунаджат Имама Зайн аль-Абидина</string>
    <string name="feature_munajat_desc">Пятнадцать благословенных мунаджатов из «Ас-Сахифа Ас-Саджадия», связанных с ежедневными вирдами, с возможностью читать любой мунаджат в любое время.</string>
    <string name="feature_tasbih">Электронный Тасбих</string>
    <string name="feature_tasbih_desc">Цифровой тасбих, содержащий семь избранных зикров с умным счетчиком и вибрационным откликом на каждый счет.</string>
    <string name="feature_multilingual">Многоязычная поддержка</string>
    <string name="feature_multilingual_desc">Добавлена полная поддержка для: арабского, английского, урду, хинди, малаялам, узбекского, индонезийского, французского, бенгальского и русского языков, предоставляя объяснения и переводы Аврода и Мунаджата.</string>
    <string name="feature_hisn">Крепость мусульманина</string>
    <string name="feature_hisn_desc">Обширная библиотека азкаров, включая: утренние и вечерние, перед сном, молитвенные, при приеме пищи, в путешествии и для мечети.</string>
    <string name="feature_notifications">Напоминания</string>
    <string name="feature_notifications_desc">Продвинутая система уведомлений, позволяющая устанавливать интервалы напоминаний (от 5 минут до 3 часов) для Истигфара и Салавата.</string>
    <string name="footer_dua">Просим Всевышнего Аллаха принять этот труд исключительно ради Его благородного Лика, принести им пользу мусульманам и поместить его на чашу добрых дел каждого, кто внес в него свой вклад.</string>
    <string name="footer_ameen">Аминь, о Господь миров.</string>

