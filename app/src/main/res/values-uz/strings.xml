    <!-- About App Strings -->
    <string name="app_name_title">Аврод Иловаси</string>
    <string name="app_version">Версия 2.3.2</string>
    <string name="about_app_desc_1">Аврод - бу Имом Зайн ул-Обидин (а.с) нинг кундалик зикрлари ва муножотларини жамлаган кенг қамровли исломий илова. Кундалик ҳаётингизда Аллоҳни зикр қилиш ва дуо қилишда барқарор бўлишингизга ёрдам бериш учун мўлжалланган.</string>
    <string name="about_app_desc_2">Илова кўзга ёқимли, содда ва фойдаланиш учун қулай дизайнга эга бўлиб, ибодат ва руҳиятга эътибор қаратишингизга ёрдам беради.</string>
    <string name="app_features">Илова хусусиятлари</string>
    <string name="feature_awrad">Кундалик Вирдлар</string>
    <string name="feature_awrad_desc">Ҳафтанинг ҳар бир куни учун етти хил вирд, Пайғамбар ﷺ га саловотлар ва муборак дуоларни ўз ичига олади.</string>
    <string name="feature_munajat">Имом Зайн ул-Обидин муножотлари</string>
    <string name="feature_munajat_desc">Саҳифаи Сажжодиядан ўн беш муборак муножот, кундалик вирдларга боғланган ҳолда, исталган вақтда ўқиш имконияти билан.</string>
    <string name="feature_tasbih">Электрон Тасбеҳ</string>
    <string name="feature_tasbih_desc">Ақлли ҳисоблагич ва ҳар бир саноқ учун вибрацияли етти танланган зикрни ўз ичига олган рақамли тасбеҳ.</string>
    <string name="feature_multilingual">Кўп тилли қўллаб-қувватлаш</string>
    <string name="feature_multilingual_desc">Араб, Инглиз, Урду, Ҳинд, Малаялам ва Ўзбек тиллари учун тўлиқ қўллаб-қувватлаш, Вирд ва Муножотларнинг таржималари ва изоҳлари билан.</string>
    <string name="feature_hisn">Ҳиснул Муслим</string>
    <string name="feature_hisn_desc">Тонгги ва кечки, уйқу, намоз, таом, сафар ва масжид зикрларини ўз ичига олган кенг қамровли зикрлар тўплами.</string>
    <string name="feature_notifications">Эслатма билдиришномалари</string>
    <string name="feature_notifications_desc">Истиғфор ва Саловот учун эслатма оралиқларини (5 дақиқадан 3 соатгача) созлаш имконини берувчи тизим.</string>
    <string name="footer_dua">Аллоҳ таолодан ушбу ишни Ўзининг розилиги учун қабул қилишини, мусулмонларга фойдали қилишини ва бунга ҳисса қўшганларнинг яхшиликлари мезонига қўшишини сўраймиз.</string>
    <string name="footer_ameen">Омин, Ё Роббил Аламийн</string>

