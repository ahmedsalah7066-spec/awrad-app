    <!-- About App Strings -->
    <string name="app_name_title">Application Awrad</string>
    <string name="app_version">Version 2.3.2</string>
    <string name="about_app_desc_1">Awrad est une application islamique complète qui rassemble les Adhkar quotidiens et les Munajat de l\'Imam Zayn al-Abidin (AS). Conçue pour vous aider à maintenir une constance dans l\'évocation et l\'invocation dans votre vie quotidienne.</string>
    <string name="about_app_desc_2">L\'application propose une interface simple et conviviale, avec un design élégant et reposant pour les yeux, vous aidant à vous concentrer sur l\'adoration et la spiritualité.</string>
    <string name="app_features">Fonctionnalités</string>
    <string name="feature_awrad">Awrad Quotidiens</string>
    <string name="feature_awrad_desc">Sept wirds différents pour chaque jour de la semaine, contenant des prières sur le Prophète ﷺ et des supplications bénies, entièrement vocalisées pour une prononciation correcte.</string>
    <string name="feature_munajat">Munajat de l\'Imam Zayn al-Abidin</string>
    <string name="feature_munajat_desc">Quinze Munajat bénis d\'Al-Sahifa Al-Sajjadiyya, liés aux wirds quotidiens, avec la possibilité de lire n\'importe quel Munajat à tout moment.</string>
    <string name="feature_tasbih">Tasbih Électronique</string>
    <string name="feature_tasbih_desc">Chapelet numérique contenant sept dhikrs sélectionnés, avec un compteur intelligent et un retour de vibration à chaque compte.</string>
    <string name="feature_multilingual">Support Multilingue</string>
    <string name="feature_multilingual_desc">Support complet ajouté pour : Arabe, Anglais, Ourdou, Hindi, Malayalam, Français, et bien d\'autres, fournissant des explications et des traductions pour les Awrad et les Munajat.</string>
    <string name="feature_hisn">Hisn Al-Muslim</string>
    <string name="feature_hisn_desc">Bibliothèque complète d\'Adhkar comprenant : les invocations du matin et du soir, du sommeil, de la prière, de la nourriture, du voyage et de la mosquée.</string>
    <string name="feature_notifications">Notifications de Rappel</string>
    <string name="feature_notifications_desc">Système de notification avancé vous permettant de définir des intervalles de rappel (de 5 minutes à 3 heures) pour l\'Istighfar et les Salawat.</string>
    <string name="footer_dua">Nous demandons à Allah le Très-Haut d\'accepter ce travail purement pour Son noble Visage, d\'en faire profiter les musulmans, et de le placer dans la balance des bonnes actions de tous ceux qui y ont contribué.</string>
    <string name="footer_ameen">Amine, Ô Seigneur des mondes</string>

