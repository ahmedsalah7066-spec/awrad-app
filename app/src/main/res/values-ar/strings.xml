    <!-- About App Strings -->
    <string name="app_name_title">تطبيق أوراد</string>
    <string name="app_version">الإصدار 2.3.2</string>
    <string name="about_app_desc_1">أوراد هو تطبيق إسلامي شامل يجمع بين الأذكار اليومية ومناجاة الإمام زين العابدين (عليه السلام). صُمم لمساعدتك على المداومة على الذكر والدعاء في حياتك اليومية.</string>
    <string name="about_app_desc_2">يتميز التطبيق بواجهة بسيطة وسهلة الاستخدام، مع تصميم أنيق مريح للعين يساعدك على التركيز في العبادة والروحانية.</string>
    <string name="app_features">ميزات التطبيق</string>
    <string name="feature_awrad">الأوراد اليومية</string>
    <string name="feature_awrad_desc">سبعة أوراد مختلفة لكل يوم من أيام الأسبوع، تحتوي على صلوات على النبي ﷺ و أدعية مباركة مشكولة بالكامل لضمان صحة القراءة.</string>
    <string name="feature_munajat">مُناجاة الإمام زين العابدين</string>
    <string name="feature_munajat_desc">خمسة عشر مناجاة روحانية للإمام زين العابدين (ع)، مرتبة لتنتقل بك في رحلة إيمانية عميقة، من التوبة إلى الشكر والذكر.</string>
    <string name="feature_hisn">حصن المسلم</string>
    <string name="feature_hisn_desc">مجموعة مختارة من الأذكار والأدعية من كتاب حصن المسلم، مصنفة لسهولة الوصول إليها (أذكار الصباح والمساء، النوم، الصلاة، إلخ).</string>
    <string name="feature_notifications">تنبيهات ذكية</string>
    <string name="feature_notifications_desc">نظام تنبيهات مرن يذكرك بالذكر والصلاة على النبي ﷺ في أوقات محددة، مع إمكانية تخصيص التكرار ونغمه التنبيه.</string>
    <string name="feature_settings">تخصيص كامل</string>
    <string name="feature_settings_desc">تحكم كامل في إعدادات التطبيق، حجم الخط، الوضع الليلي (تلقائي/يدوي)، ولغة التطبيق.</string>
