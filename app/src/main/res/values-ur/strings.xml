    <!-- About App Strings -->
    <string name="app_name_title">اوراد ایپ</string>
    <string name="app_version">ورژن 2.3.2</string>
    <string name="about_app_desc_1">اوراد ایک جامع اسلامی ایپ ہے جو روزانہ اذکار اور امام زین العابدین (علیہ السلام) کی مناجات کو یکجا کرتی ہے۔ یہ آپ کی روزمرہ زندگی میں مسلسل ذکر اور دعا کو برقرار رکھنے میں مدد کے لیے ڈیزائن کی گئی ہے۔</string>
    <string name="about_app_desc_2">ایپ ایک سادہ، صارف دوست انٹرفیس کے ساتھ پیش کی گئی ہے جس کا خوبصورت ڈیزائن آنکھوں پر آرام دہ ہے، جو آپ کو عبادت اور روحانیت پر توجہ مرکوز کرنے میں مدد کرتا ہے۔</string>
    <string name="app_features">ایپ کی خصوصیات</string>
    <string name="feature_awrad">روزانہ اوراد</string>
    <string name="feature_awrad_desc">ہفتے کے ہر دن کے لیے سات مختلف اوراد، جن میں نبی ﷺ پر درود اور مبارک دعائیں شامل ہیں، درست تلفظ کے لیے مکمل اعراب کے ساتھ۔</string>
    <string name="feature_munajat">امام زین العابدین کی مناجات</string>
    <string name="feature_munajat_desc">الصحیفہ السجادیہ سے پندرہ مبارک مناجاتیں، روزانہ اوراد سے منسلک، کسی بھی وقت کسی بھی مناجات کو پڑھنے کی صلاحیت کے ساتھ۔</string>
    <string name="feature_tasbih">الیکٹرانک تسبیح</string>
    <string name="feature_tasbih_desc">ڈیجیٹل تسبیح جس میں سات منتخب اذکار شامل ہیں، ہوشیار شمارندہ اور ہر شمار پر کمپن کے ساتھ۔</string>
    <string name="feature_multilingual">کثیر لسانی معاونت</string>
    <string name="feature_multilingual_desc">مکمل معاونت شامل کی گئی ہے: عربی، انگریزی، اردو، ہندی، اور ملیالم کے لیے، اوراد اور مناجاتوں کی تشریحات اور ترجمے فراہم کرتے ہوئے۔</string>
    <string name="feature_hisn">حصن المسلم</string>
    <string name="feature_hisn_desc">اذکار کی جامع لائبریری جس میں شامل ہیں: صبح و شام، نیند، نماز، کھانا، سفر، اور مسجد کے اذکار۔</string>
    <string name="feature_notifications">یاد دہانی کی اطلاعات</string>
    <string name="feature_notifications_desc">اعلیٰ اطلاع نظام جو آپ کو استغفار اور درود کے لیے یاد دہانی کے وقفے (5 منٹ سے 3 گھنٹے تک) مقرر کرنے کی اجازت دیتا ہے۔</string>
    <string name="footer_dua">ہم اللہ تعالیٰ سے دعا کرتے ہیں کہ وہ اس کام کو خالص اپنی رضا کے لیے قبول فرمائے، اس سے مسلمانوں کو فائدہ پہنچائے، اور اسے ہر اس شخص کے نیک اعمال کے پلڑے میں رکھے جس نے اس میں حصہ لیا۔</string>
    <string name="footer_ameen">آمین، یا رب العالمین</string>

