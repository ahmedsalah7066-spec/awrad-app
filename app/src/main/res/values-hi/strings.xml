    <!-- About App Strings -->
    <string name="app_name_title">अवरद एप्लिकेशन</string>
    <string name="app_version">Version 2.3.2</string>
    <string name="about_app_desc_1">अवरद (Awrad) एक पूर्ण इस्लामी एप्लिकेशन है जो दैनिक अज़कार और इमाम ज़ैनुल आबिदीन (अलैहिस्सलाम) की मुनाजात एकत्र करता है। यह आपके दिन में आध्यात्मिकता बनाए रखने में मदद करता है।</string>
    <string name="about_app_desc_2">एप्लिकेशन एक आसान और शांत डिजाइन प्रदान करता है जो आंखों के लिए आरामदायक है, और आपको विशुद्ध रूप से इबादत पर ध्यान केंद्रित करने में मदद करता है।</string>
    <string name="app_features">विशेषताएँ</string>
    <string name="feature_awrad">दैनिक अवरद</string>
    <string name="feature_awrad_desc">सप्ताह के प्रत्येक दिन के लिए सात अलग-अलग विरद, जिसमें सटीक उच्चारण के साथ दरूद और आशीर्वाद शामिल हैं।</string>
    <string name="feature_munajat">इमाम ज़ैनुल आबिदीन की मुनाजात</string>
    <string name="feature_munajat_desc">सहीफा सज्जादिया से पंद्रह मुनाजात जो दैनिक विरद से जुड़े हैं, जिन्हें किसी भी समय पढ़ने का विकल्प है।</string>
    <string name="feature_tasbih">इलेक्ट्रॉनिक तस्बीह</string>
    <string name="feature_tasbih_desc">स्मार्ट काउंटर और प्रत्येक गिनती पर वाइब्रेशन के साथ डिजिटल तस्बीह।</string>
    <string name="feature_multilingual">बहुभाषी समर्थन</string>
    <string name="feature_multilingual_desc">अरबी, अंग्रेजी, उर्दू, हिंदी, मलयालम, फ्रेंच, बंगाली और अन्य भाषाओं के लिए पूर्ण समर्थन।</string>
    <string name="feature_hisn">हिसनुल मुस्लिम</string>
    <string name="feature_hisn_desc">सुबह और शाम, नींद, नमाज़, भोजन, यात्रा और मस्जिद के अज़कार का पूरा संग्रह।</string>
    <string name="feature_notifications">रिमाइंडर</string>
    <string name="feature_notifications_desc">एक उन्नत सूचना प्रणाली जो आपको इस्तिगफार और दरूद के लिए 5 मिनट से 3 घंटे तक का समय निर्धारित करने की अनुमति देती है।</string>
    <string name="footer_dua">हम अल्लाह से दुआ करते हैं कि वह इस काम को अपनी खुशी के लिए कबूल करे, मुसलमानों को इससे लाभान्वित करे, और इसे उन सबके नेक आमाल में जोड़े जिन्होंने इसमें योगदान दिया है।</string>
    <string name="footer_ameen">आमीन</string>

