    <!-- About App Strings -->
    <string name="app_name_title">Awrad App</string>
    <string name="app_version">Version 2.3.2</string>
    <string name="about_app_desc_1">Awrad is a comprehensive Islamic app combining Daily Adhkar and Munajat of Imam Zain al-Abidin (AS). Designed to help you maintain consistent remembrance and supplication in your daily life.</string>
    <string name="about_app_desc_2">The app features a simple, user-friendly interface with an elegant design that is easy on the eyes, helping you focus on worship and spirituality.</string>
    <string name="app_features">App Features</string>
    <string name="feature_awrad">Daily Awrad</string>
    <string name="feature_awrad_desc">Seven different wirds for each day of the week, containing prayers upon the Prophet ﷺ and blessed supplications fully voweled for correct pronunciation.</string>
    <string name="feature_munajat">Munajat of Imam Zain al-Abidin</string>
    <string name="feature_munajat_desc">Fifteen blessed Munajat from Al-Sahifa Al-Sajjadiyya, linked to daily wirds, with the ability to read any Munajat at any time.</string>
    <string name="feature_tasbih">Electronic Tasbih</string>
    <string name="feature_tasbih_desc">Digital tasbih containing seven selected dhikrs with a smart counter and vibration feedback on each count.</string>
    <string name="feature_multilingual">12 Languages Support</string>
    <string name="feature_multilingual_desc">Full support for 12 languages, providing worldwide access to explanations and translations for Awrad and Munajat.</string>
    <string name="feature_sharing">Content Sharing</string>
    <string name="feature_sharing_desc">Easily share Awrad, Munajat, and Adhkar with your friends and family.</string>
    <string name="feature_hisn">Hisn Al-Muslim</string>
    <string name="feature_hisn_desc">Comprehensive library of Adhkar including: Morning &amp; Evening, Sleep, Prayer, Food, Travel, and Mosque Adhkar.</string>
    <string name="feature_notifications">Reminder Notifications</string>
    <string name="feature_notifications_desc">Advanced notification system allowing you to set reminder intervals (from 5 minutes to 3 hours) for Istighfar and Salawat.</string>
    <string name="footer_dua">We ask Allah the Almighty to accept this work purely for His noble sake, to benefit Muslims with it, and to place it in the scale of good deeds of everyone who contributed to it.</string>
    <string name="footer_ameen">Ameen, O Lord of the Worlds</string>
