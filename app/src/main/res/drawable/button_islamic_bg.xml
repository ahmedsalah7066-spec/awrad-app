<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#D4AF37">
    <item>
        <layer-list>
            <!-- Main Background Gradient -->
            <item>
                <shape android:shape="rectangle">
                    <gradient android:angle="45" android:startColor="#1E5631" android:endColor="#2E7D45" android:type="linear" />
                    <corners android:radius="16dp" />
                </shape>
            </item>

            <!-- Outer Gold Border -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="#D4AF37" />
                    <corners android:radius="16dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>

            <!-- Inner Decorative Border (Inset) -->
            <item android:bottom="5dp" android:left="5dp" android:right="5dp" android:top="5dp">
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#B49120" android:dashGap="3dp" android:dashWidth="6dp" />
                    <corners android:radius="12dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
