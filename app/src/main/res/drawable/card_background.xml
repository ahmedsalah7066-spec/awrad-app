<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid White Background (Paper Effect) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFEF9" />
            <!-- Warmer paper-white -->
            <corners android:radius="12dp" />
            <stroke android:width="1.5dp" android:color="#E8E4D0" />
            <!-- Subtle beige stroke -->
        </shape>
    </item>

    <!-- Inner Gold Decorative Borders -->
    <item android:bottom="8dp" android:left="8dp" android:right="8dp" android:top="8dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="#C5A059" />
            <!-- Elegant Gold -->
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Subtle Drop Shadow Simulation -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="12dp" />
            <stroke android:width="0.5dp" android:color="#20000000" />
            <!-- Very faint shadow line -->
        </shape>
    </item>
</layer-list>
