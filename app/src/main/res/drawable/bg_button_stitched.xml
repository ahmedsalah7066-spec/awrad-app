<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/primaryGreen" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Stitched/Dashed Border Inset -->
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="#80FFFFFF" android:dashGap="4dp" android:dashWidth="4dp" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
